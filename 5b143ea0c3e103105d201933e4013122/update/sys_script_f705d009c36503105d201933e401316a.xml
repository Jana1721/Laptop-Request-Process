        <script><![CDATA[(function executeRule(current, previous /*null when async*/ ) {

    var assign = new GlideRecord('u_laptop_assignment');
    assign.initialize();
    assign.u_request = current.sys_id;
    assign.u_laptop = current.u_laptop_model;
    assign.u_assigned_to = current.opened_by;
    assign.u_assigned_by = gs.getUserID();
    assign.u_assignment_date = new GlideDateTime();
    assign.insert();

    var catalog = new GlideRecord('u_laptop_catalog');
    if (catalog.get(current.u_laptop_model)) {
        var stock = parseInt(catalog.u_available_stock);
        if (stock > 0) {
            catalog.u_available_stock = stock - 1;
            catalog.update();
        }
    }

    current.approval_status = 'assigned';


})(current, previous);]]></script>
